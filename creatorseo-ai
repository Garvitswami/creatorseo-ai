<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>CreatorSEO AI Tool</title>
<style>
body {
    font-family: Arial, sans-serif;
    background: #f5f5f5;
    margin: 0;
    padding: 20px;
}
h1 {
    text-align: center;
    margin-bottom: 20px;
    color: #333;
}
.container {
    max-width: 500px;
    margin: 0 auto;
    background: #fff;
    padding: 20px;
    border-radius: 12px;
    box-shadow: 0 0 15px rgba(0,0,0,0.1);
}
input, select, button {
    width: 100%;
    padding: 12px;
    margin: 10px 0;
    border-radius: 8px;
    border: 1px solid #ccc;
    font-size: 16px;
}
button {
    background: #4CAF50;
    color: white;
    border: none;
    cursor: pointer;
    font-weight: bold;
}
button:hover {
    background: #45a049;
}
.result {
    margin-top: 20px;
    background: #f0f0f0;
    padding: 15px;
    border-radius: 8px;
    word-wrap: break-word;
}
.result h3 {
    margin-bottom: 5px;
    color: #555;
}
</style>
</head>
<body>

<h1>CreatorSEO AI Tool</h1>

<div class="container">
    <input type="text" id="niche" placeholder="Enter your niche (e.g., Summer Recipes)">
    <select id="platform">
        <option>YouTube</option>
        <option>Blog</option>
        <option>Pinterest</option>
    </select>
    <button onclick="generate()">Generate Ideas</button>

    <div class="result" id="output"></div>
</div>

<script>
function generate() {
    let niche = document.getElementById("niche").value.trim();
    let platform = document.getElementById("platform").value;

    if(!niche){
        alert("Please enter a niche!");
        return;
    }

    let result = `
    <h3>SEO Keywords:</h3>
    - Best ${niche} ideas
    - ${niche} for beginners
    - Viral ${niche} 2026
    - How to ${niche} fast
    - ${niche} tips & tricks

    <h3>${platform} Titles:</h3>
    - 10 Amazing ${niche} Ideas That Go Viral
    - Secret ${niche} Strategies No One Tells You
    - ${niche} Hacks for Beginners
    - How to Master ${niche} in 7 Days

    <h3>Hashtags:</h3>
    #${niche.replace(/\s+/g,'')} #viral #trending #${platform.toLowerCase()} #contentcreator
    `;

    document.getElementById("output").innerHTML = result;
}
</script>

</body>
</html>
